@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

:root {
  --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  --secondary-gradient: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
  --accent-gradient: linear-gradient(135deg, #ff9a9e 0%, #fecfef 50%, #fecfef 100%);
  --dark-gradient: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
  --glass-bg: rgba(255, 255, 255, 0.08);
  --glass-border: rgba(255, 255, 255, 0.15);
  --glow-primary: rgba(102, 126, 234, 0.6);
  --glow-secondary: rgba(246, 147, 251, 0.6);
  --shadow-soft: 0 8px 32px rgba(0, 0, 0, 0.1);
  --shadow-strong: 0 16px 64px rgba(0, 0, 0, 0.2);
  --blur-light: blur(20px);
  --blur-heavy: blur(40px);
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  background: linear-gradient(135deg, #0f0f23 0%, #1a1a2e 25%, #16213e 50%, #0f3460 75%, #1a1a2e 100%);
  background-attachment: fixed;
  min-height: 100vh;
  overflow-x: hidden;
}

body::before {
  content: '';
  position: fixed;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.1) 0%, transparent 50%),
              radial-gradient(circle at 80% 20%, rgba(246, 147, 251, 0.1) 0%, transparent 50%),
              radial-gradient(circle at 20% 80%, rgba(255, 154, 158, 0.1) 0%, transparent 50%);
  animation: float 20s ease-in-out infinite;
  z-index: -1;
}

@keyframes float {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(30px, -30px) rotate(120deg); }
  66% { transform: translate(-20px, 20px) rotate(240deg); }
}

.app-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
  position: relative;
}

.glass-morphism {
  background: var(--glass-bg);
  backdrop-filter: var(--blur-light);
  border: 1px solid var(--glass-border);
  border-radius: 24px;
  box-shadow: var(--shadow-soft);
  position: relative;
  overflow: hidden;
}

.glass-morphism::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--primary-gradient);
  opacity: 0.05;
  border-radius: 24px;
  z-index: -1;
}

.glass-morphism-advanced {
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.1) 0%,
    rgba(255, 255, 255, 0.05) 50%,
    rgba(255, 255, 255, 0.02) 100%);
  backdrop-filter: var(--blur-heavy);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 32px;
  box-shadow:
    0 8px 32px rgba(0, 0, 0, 0.1),
    0 0 0 1px rgba(255, 255, 255, 0.1) inset,
    0 0 60px rgba(102, 126, 234, 0.1);
  position: relative;
  overflow: hidden;
}

.glass-morphism-advanced::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: conic-gradient(
    from 0deg,
    transparent 0deg,
    rgba(102, 126, 234, 0.1) 60deg,
    rgba(246, 147, 251, 0.1) 120deg,
    rgba(255, 154, 158, 0.1) 180deg,
    rgba(102, 126, 234, 0.1) 240deg,
    transparent 300deg
  );
  animation: rotate 10s linear infinite;
  z-index: -1;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.main-content {
  max-width: 1400px;
  width: 100%;
  position: relative;
}

.hero-section {
  text-align: center;
  margin-bottom: 6rem;
  position: relative;
  padding: 4rem 2rem;
}

.hero-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120%;
  height: 120%;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.1) 0%, transparent 70%);
  border-radius: 50%;
  animation: hero-glow-pulse 4s ease-in-out infinite;
  z-index: -1;
}

@keyframes hero-glow-pulse {
  0%, 100% { opacity: 0.3; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: 0.6; transform: translate(-50%, -50%) scale(1.1); }
}

.hero-title {
  font-size: clamp(2.5rem, 6vw, 5rem);
  font-weight: 900;
  line-height: 1.1;
  margin-bottom: 2rem;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
}

.hero-title-main {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-size: 200% 200%;
  animation: gradient-shift 4s ease-in-out infinite, text-glow 3s ease-in-out infinite;
  text-shadow: 0 0 60px rgba(102, 126, 234, 0.4);
  letter-spacing: -0.02em;
}

.hero-title-sub {
  color: rgba(255, 255, 255, 0.9);
  font-size: 0.6em;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  opacity: 0.8;
}

@keyframes text-glow {
  0%, 100% { text-shadow: 0 0 40px rgba(102, 126, 234, 0.3); }
  50% { text-shadow: 0 0 60px rgba(102, 126, 234, 0.6), 0 0 80px rgba(246, 147, 251, 0.3); }
}

.hero-subtitle {
  font-size: clamp(1rem, 2vw, 1.4rem);
  font-weight: 400;
  color: rgba(255, 255, 255, 0.85);
  max-width: 700px;
  margin: 0 auto 3rem auto;
  line-height: 1.7;
  backdrop-filter: blur(15px);
  padding: 1.5rem;
  border-radius: 20px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  position: relative;
  overflow: hidden;
}

.hero-subtitle::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);
  animation: shimmer 3s ease-in-out infinite;
}

@keyframes shimmer {
  0% { left: -100%; }
  100% { left: 100%; }
}

.hero-stats {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 3rem;
  margin-top: 2rem;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  padding: 1rem;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10px);
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  min-width: 100px;
  transition: all 0.3s ease;
}

.stat-item:hover {
  transform: translateY(-2px);
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(102, 126, 234, 0.3);
}

.stat-number {
  font-size: 1.5rem;
  font-weight: 800;
  color: #667eea;
  text-shadow: 0 0 20px rgba(102, 126, 234, 0.5);
}

.stat-label {
  font-size: 0.9rem;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.upload-section {
  max-width: 900px;
  margin: 0 auto 6rem auto;
}

.features-section {
  margin-bottom: 6rem;
}

.features-title {
  font-size: clamp(2rem, 4vw, 2.5rem);
  font-weight: 700;
  color: white;
  text-align: center;
  margin-bottom: 4rem;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.7) 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 2.5rem;
  margin-top: 3rem;
}

.feature-card {
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.08) 0%,
    rgba(255, 255, 255, 0.04) 50%,
    rgba(255, 255, 255, 0.02) 100%);
  backdrop-filter: blur(25px);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 24px;
  padding: 3rem 2rem;
  text-align: center;
  transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  box-shadow:
    0 8px 32px rgba(0, 0, 0, 0.12),
    0 0 0 1px rgba(255, 255, 255, 0.05) inset;
}

.feature-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.03) 0%, rgba(246, 147, 251, 0.03) 100%);
  opacity: 0;
  transition: opacity 0.5s ease;
  z-index: -1;
}

.feature-card:hover {
  transform: translateY(-12px) scale(1.02);
  box-shadow:
    0 20px 60px rgba(0, 0, 0, 0.25),
    0 0 0 1px rgba(102, 126, 234, 0.2) inset,
    0 0 80px rgba(102, 126, 234, 0.15);
  border-color: rgba(102, 126, 234, 0.3);
}

.feature-card:hover::before {
  opacity: 1;
}

.feature-icon-wrapper {
  width: 80px;
  height: 80px;
  margin: 0 auto 2rem auto;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.2) 0%, rgba(246, 147, 251, 0.2) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid rgba(255, 255, 255, 0.15);
  transition: all 0.4s ease;
}

.feature-card:hover .feature-icon-wrapper {
  transform: scale(1.1) rotate(5deg);
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.3) 0%, rgba(246, 147, 251, 0.3) 100%);
  border-color: rgba(102, 126, 234, 0.4);
  box-shadow: 0 0 30px rgba(102, 126, 234, 0.3);
}

.feature-icon {
  font-size: 2.5rem;
  animation: icon-float 3s ease-in-out infinite;
}

@keyframes icon-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-5px); }
}

.feature-title {
  font-size: 1.4rem;
  font-weight: 700;
  color: white;
  margin-bottom: 1.2rem;
  text-shadow: 0 1px 10px rgba(0, 0, 0, 0.3);
}

.feature-description {
  color: rgba(255, 255, 255, 0.75);
  line-height: 1.6;
  font-size: 1rem;
  font-weight: 400;
}

.footer {
  margin-top: 6rem;
  padding: 3rem 0;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.footer-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2rem;
}

.footer-text {
  color: rgba(255, 255, 255, 0.6);
  font-size: 0.9rem;
  font-weight: 500;
}

.footer-links {
  display: flex;
  gap: 2rem;
}

.footer-link {
  color: rgba(255, 255, 255, 0.6);
  text-decoration: none;
  font-size: 0.9rem;
  font-weight: 500;
  transition: all 0.3s ease;
  padding: 0.5rem 1rem;
  border-radius: 8px;
}

.footer-link:hover {
  color: rgba(102, 126, 234, 0.9);
  background: rgba(102, 126, 234, 0.1);
  transform: translateY(-1px);
}

.upload-zone {
  background: linear-gradient(135deg,
    rgba(255, 255, 255, 0.1) 0%,
    rgba(255, 255, 255, 0.05) 50%,
    rgba(255, 255, 255, 0.02) 100%);
  backdrop-filter: blur(40px);
  border: 2px dashed rgba(255, 255, 255, 0.3);
  border-radius: 32px;
  position: relative;
  overflow: hidden;
  padding: 3rem;
  margin-bottom: 2rem;
  text-align: center;
  cursor: pointer;
  transition: all 0.5s ease-out;
  min-height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-zone::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(102, 126, 234, 0.1), transparent);
  transition: left 0.5s;
}

.upload-zone:hover::before {
  left: 100%;
}

.upload-zone:hover {
  border-color: var(--glow-primary);
  box-shadow: 0 0 50px var(--glow-primary);
  transform: translateY(-4px);
}

.upload-zone.dragover {
  border-color: var(--glow-secondary);
  background: rgba(246, 147, 251, 0.1);
  transform: scale(1.02);
  box-shadow: 0 0 60px var(--glow-secondary);
}

.upload-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.5rem;
}

.upload-icon {
  font-size: 4rem;
  margin-bottom: 2rem;
  background: var(--primary-gradient);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  filter: drop-shadow(0 0 20px rgba(102, 126, 234, 0.5));
  animation: pulse-glow 3s ease-in-out infinite;
}

.upload-text {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.upload-title {
  font-size: 2rem;
  font-weight: 700;
  color: white;
  margin-bottom: 1rem;
  text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
}

.upload-subtitle {
  font-size: 1.1rem;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 1.5rem;
  max-width: 400px;
  margin-left: auto;
  margin-right: auto;
}

.upload-limit {
  font-size: 0.9rem;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
  padding: 0.5rem 1rem;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20px;
  display: inline-block;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.selected-file-display {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  max-width: 500px;
}

.file-icon {
  font-size: 3rem;
  opacity: 0.8;
}

.file-info {
  flex: 1;
  text-align: left;
}

.file-name {
  font-size: 1.3rem;
  font-weight: 600;
  color: white;
  margin-bottom: 0.5rem;
  word-break: break-all;
}

.file-size {
  color: rgba(255, 255, 255, 0.7);
  font-size: 0.9rem;
}

.clear-file {
  background: rgba(239, 68, 68, 0.2);
  border: 1px solid rgba(239, 68, 68, 0.3);
  color: #fca5a5;
  padding: 0.5rem 0.75rem;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.3s ease;
  font-weight: 500;
  font-size: 1.2rem;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-file:hover {
  background: rgba(239, 68, 68, 0.3);
  transform: scale(1.1);
}

.action-section {
  text-align: center;
  margin-bottom: 2rem;
}

.convert-button {
  background: var(--primary-gradient);
  border: none;
  color: white;
  font-size: 1.3rem;
  font-weight: 700;
  padding: 1.2rem 3.5rem;
  border-radius: 25px;
  cursor: pointer;
  transition: all 0.4s ease;
  box-shadow: 0 4px 20px rgba(102, 126, 234, 0.4);
  position: relative;
  overflow: hidden;
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
}

.convert-button::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s;
}

.convert-button:hover::before {
  left: 100%;
}

.convert-button:hover {
  transform: translateY(-3px) scale(1.05);
  box-shadow: 0 10px 35px rgba(102, 126, 234, 0.6);
}

.convert-button:active {
  transform: translateY(0) scale(1);
}

.button-text {
  font-size: 1.3rem;
}

.button-icon {
  font-size: 1.2rem;
  animation: pulse 2s infinite;
}

.progress-status {
  margin-top: 1rem;
  text-align: center;
}

.status-text {
  color: rgba(255, 255, 255, 0.6);
  font-size: 0.9rem;
  font-style: italic;
}

.download-text {
  font-weight: 600;
}

.download-icon {
  font-size: 1.1rem;
  margin-left: 0.5rem;
}

.upload-icon {
  font-size: 4rem;
  margin-bottom: 2rem;
  background: var(--primary-gradient);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  filter: drop-shadow(0 0 20px rgba(102, 126, 234, 0.5));
  animation: pulse-glow 3s ease-in-out infinite;
}

@keyframes pulse-glow {
  0%, 100% {
    filter: drop-shadow(0 0 20px rgba(102, 126, 234, 0.5));
    transform: scale(1);
  }
  50% {
    filter: drop-shadow(0 0 30px rgba(102, 126, 234, 0.8));
    transform: scale(1.05);
  }
}

.upload-title {
  font-size: 2rem;
  font-weight: 700;
  color: white;
  margin-bottom: 1rem;
  text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
}

.upload-subtitle {
  font-size: 1.1rem;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 1.5rem;
  max-width: 400px;
  margin-left: auto;
  margin-right: auto;
}

.upload-limit {
  font-size: 0.9rem;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
  padding: 0.5rem 1rem;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20px;
  display: inline-block;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.selected-file {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(102, 126, 234, 0.3);
  border-radius: 16px;
  padding: 1.5rem;
  margin-bottom: 1.5rem;
  background-color: rgba(102, 126, 234, 0.1);
}

.file-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.file-name {
  font-size: 1.2rem;
  font-weight: 600;
  color: white;
}

.file-size {
  color: rgba(255, 255, 255, 0.7);
  font-size: 0.9rem;
}

.clear-file {
  background: rgba(239, 68, 68, 0.2);
  border: 1px solid rgba(239, 68, 68, 0.3);
  color: #fca5a5;
  padding: 0.5rem 1rem;
  border-radius: 12px;
  cursor: pointer;
  transition: all 0.3s ease;
  font-weight: 500;
}

.clear-file:hover {
  background: rgba(239, 68, 68, 0.3);
  transform: scale(1.05);
}

.convert-button {
  background: var(--primary-gradient);
  border: none;
  color: white;
  font-size: 1.2rem;
  font-weight: 700;
  padding: 1rem 3rem;
  border-radius: 20px;
  cursor: pointer;
  transition: all 0.4s ease;
  box-shadow: 0 4px 20px rgba(102, 126, 234, 0.4);
  position: relative;
  overflow: hidden;
}

.convert-button::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s;
}

.convert-button:hover::before {
  left: 100%;
}

.convert-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(102, 126, 234, 0.6);
}

.convert-button:active {
  transform: translateY(0);
}

.progress-container {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(102, 126, 234, 0.3);
  border-radius: 16px;
  padding: 1.5rem;
  margin-bottom: 1.5rem;
  background-color: rgba(102, 126, 234, 0.1);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1rem;
}

.progress-title {
  color: white;
  font-weight: 600;
}

.progress-percentage {
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

.progress-bar-container {
  width: 100%;
  height: 8px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4px;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: var(--primary-gradient);
  border-radius: 4px;
  transition: width 0.3s ease;
  box-shadow: 0 0 20px rgba(102, 126, 234, 0.5);
}

.success-container {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(34, 197, 94, 0.3);
  border-radius: 16px;
  padding: 1.5rem;
  margin-bottom: 1.5rem;
  background-color: rgba(34, 197, 94, 0.1);
}

.success-content {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.success-icon {
  color: #22c55e;
  font-size: 1.5rem;
}

.success-text {
  flex: 1;
}

.success-title {
  color: #22c55e;
  font-weight: 600;
  margin-bottom: 0.5rem;
}

.success-message {
  color: rgba(255, 255, 255, 0.8);
}

.download-link {
  background: rgba(34, 197, 94, 0.2);
  border: 1px solid rgba(34, 197, 94, 0.3);
  color: #4ade80;
  padding: 0.75rem 1.5rem;
  border-radius: 12px;
  text-decoration: none;
  font-weight: 500;
  transition: all 0.3s ease;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}

.download-link:hover {
  background: rgba(34, 197, 94, 0.3);
  transform: translateY(-1px);
}

.error-container {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: 16px;
  padding: 1.5rem;
  margin-bottom: 1.5rem;
  background-color: rgba(239, 68, 68, 0.1);
}

.error-content {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.error-icon {
  color: #ef4444;
  font-size: 1.5rem;
}

.error-text {
  color: #fca5a5;
  font-weight: 500;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 2rem;
  margin-top: 4rem;
}

.feature-card {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 2rem;
  text-align: center;
  transition: all 0.4s ease;
}

.feature-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
  border-color: var(--glow-primary);
}

.feature-icon {
  font-size: 3rem;
  margin-bottom: 1.5rem;
  display: block;
}

.feature-title {
  font-size: 1.3rem;
  font-weight: 700;
  color: white;
  margin-bottom: 1rem;
}

.feature-description {
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
}

/* Responsive Design */
@media (max-width: 768px) {
  .app-container {
    padding: 1rem;
  }

  .hero-section {
    margin-bottom: 3rem;
    padding: 2rem 1rem;
  }

  .hero-title {
    font-size: 2.5rem;
  }

  .hero-subtitle {
    font-size: 1rem;
    padding: 1rem;
  }

  .hero-stats {
    flex-direction: column;
    gap: 1rem;
  }

  .upload-zone {
    padding: 2rem 1.5rem;
    min-height: 180px;
  }

  .upload-title {
    font-size: 1.5rem;
  }

  .upload-subtitle {
    font-size: 1rem;
  }

  .selected-file-display {
    flex-direction: column;
    text-align: center;
    gap: 1rem;
  }

  .file-info {
    text-align: center;
  }

  .convert-button {
    font-size: 1.1rem;
    padding: 1rem 2.5rem;
  }

  .button-text {
    font-size: 1.1rem;
  }

  .features-grid {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .feature-card {
    padding: 2rem 1.5rem;
  }

  .footer-content {
    flex-direction: column;
    gap: 1rem;
    text-align: center;
  }

  .footer-links {
    justify-content: center;
  }
}

@media (max-width: 480px) {
  .hero-section {
    padding: 1.5rem 1rem;
  }

  .hero-title {
    font-size: 2rem;
  }

  .hero-subtitle {
    font-size: 0.9rem;
    padding: 0.75rem;
  }

  .upload-zone {
    padding: 1.5rem 1rem;
    border-radius: 24px;
  }

  .upload-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .upload-title {
    font-size: 1.3rem;
  }

  .convert-button {
    font-size: 1rem;
    padding: 0.9rem 2rem;
  }

  .feature-card {
    padding: 1.5rem 1rem;
  }

  .features-title {
    font-size: 1.8rem;
  }
}

/* Custom scrollbar */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.5);
}

/* Loading animations */
@keyframes shimmer {
  0% { background-position: -200px 0; }
  100% { background-position: calc(200px + 100%) 0; }
}

.loading-shimmer {
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.1) 25%, rgba(255, 255, 255, 0.2) 50%, rgba(255, 255, 255, 0.1) 75%);
  background-size: 200px 100%;
  animation: shimmer 1.5s infinite;
}
