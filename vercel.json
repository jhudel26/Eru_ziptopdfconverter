{
  "version": 2,
  "functions": {
    "api/upload.js": {
      "runtime": "nodejs18",
      "maxDuration": 30
    },
    "api/download.js": {
      "runtime": "nodejs18", 
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}
