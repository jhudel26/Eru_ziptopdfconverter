{
  "version": 2,
  "functions": {
    "api/upload.js": {
      "runtime": "@vercel/node",
      "maxDuration": 30
    },
    "api/download.js": {
      "runtime": "@vercel/node", 
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}
